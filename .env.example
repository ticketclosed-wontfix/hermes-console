# ── Hermes Console Environment Variables ────────────────

# Ingest secret for the notification endpoint.
# The gateway (hermes-agent) must send this as X-Hermes-Ingest-Secret header.
# If not set, an ephemeral secret is generated at startup (changes on restart).
HERMES_CONSOLE_INGEST_SECRET=

# GitHub personal access token with repo read scope.
# Required for /api/github/* routes (repos, issues, pulls, checks).
# Scopes needed: repo (for private repos), read:org (optional).
HERMES_GITHUB_TOKEN=

# Gateway URL (the hermes-agent process)
HERMES_GATEWAY_URL=http://127.0.0.1:8642

# API key for gateway proxy (matches the gateway's API_SERVER_KEY)
API_SERVER_KEY=

# State DB path (defaults to ~/.hermes/state.db)
HERMES_STATE_DB=

# Port (defaults to 3001)
PORT=3001